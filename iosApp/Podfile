platform :ios, '16.0'

target 'iosApp' do
  use_frameworks! :linkage => :static

  # Le module shared tirera Firebase 11.4.0
  pod 'shared', :path => '../shared'

  post_install do |installer|
    # On récupère le chemin Java de manière plus robuste
    java_path = `/usr/libexec/java_home -v 17 2>/dev/null || echo $JAVA_HOME_17_X64`.strip
    if java_path.empty?
      java_path = `/usr/libexec/java_home -v 17`.strip rescue "/Library/Java/JavaVirtualMachines/temurin-17.jdk/Contents/Home"
    end

    installer.pods_project.targets.each do |target|
      # On injecte Java dans tous les scripts qui appellent gradlew
      target.build_phases.each do |phase|
        if phase.respond_to?(:shell_script) && phase.shell_script.include?('gradlew')
          phase.shell_script = "export JAVA_HOME=\"#{java_path}\"\nexport PATH=\"$JAVA_HOME/bin:$PATH\"\n" + phase.shell_script
        end
      end

      target.build_configurations.each do |config|
        config.build_settings['ENABLE_USER_SCRIPT_SANDBOXING'] = 'NO'
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '16.0'
        config.build_settings['ENABLE_BITCODE'] = 'NO'
        config.build_settings['GENERATE_MASTER_OBJECT_FILE'] = 'NO'
        config.build_settings['CLANG_ENABLE_CODE_COVERAGE'] = 'NO'
        config.build_settings['LLVM_LTO'] = 'NO'
        config.build_settings['DEBUG_INFORMATION_FORMAT'] = 'dwarf' # Pas de dSYM pour la rapidité CI

        # Correction pour les Pods sans Bundle ID
        if config.build_settings['PRODUCT_BUNDLE_IDENTIFIER'].nil?
           config.build_settings['PRODUCT_BUNDLE_IDENTIFIER'] = "com.inchios.agenda.pod.#{target.name.gsub(' ', '-')}"
        end

        # SUPPRESSION RADICALE DU FLAG -G (Source du crash Xcode 16)
        ['OTHER_CFLAGS', 'OTHER_CPLUSPLUSFLAGS', 'OTHER_LDFLAGS', 'OTHER_SWIFT_FLAGS'].each do |key|
          if config.build_settings[key]
            if config.build_settings[key].is_a?(Array)
              config.build_settings[key].reject! { |f| f == '-G' || f.include?('serialize-diagnostics') }
            else
              config.build_settings[key] = config.build_settings[key].gsub(/-G\s?/, '').gsub(/--serialize-diagnostics\s?/, '').strip
            end
          end
        end

        # CORRECTIF BoringSSL-GRPC et gRPC : Désactivation ASM et nettoyage
        if target.name.include?('BoringSSL-GRPC') || target.name.include?('gRPC') || target.name.include?('FirebaseFirestore') || target.name.include?('abseil')
          config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= ['$(inherited)']
          config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] << 'GRPC_BAZEL_BUILD=1'
          config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] << 'OPENSSL_NO_ASM=1'
          config.build_settings['USE_HEADER_MAP'] = 'NO'

          # ANTI-FLAG -G : On désactive tout ce qui injecte ce flag
          config.build_settings['GCC_GENERATE_DEBUGGING_SYMBOLS'] = 'NO'
          config.build_settings['ENABLE_DEBUG_INCREMENTAL_BUILD'] = 'NO'
          config.build_settings['STRIP_INSTALLED_PRODUCT'] = 'YES'
          config.build_settings['CLANG_SERIALIZE_DIAGNOSTICS'] = 'NO'
        end
      end
    end
  end
end
