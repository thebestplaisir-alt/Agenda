platform :ios, '16.0'

# Désactive les scripts utilisateur de CocoaPods pour éviter l'erreur 65
install! 'cocoapods', :skip_user_script_phases => true

target 'iosApp' do
  # Retour au lien statique pour Firebase, plus performant
  use_frameworks! :linkage => :static
  use_modular_headers!

  pod 'shared', :path => '../shared'

  post_install do |installer|
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        config.build_settings['ENABLE_USER_SCRIPT_SANDBOXING'] = 'NO'
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '16.0'
        config.build_settings['CLANG_SERIALIZE_DIAGNOSTICS'] = 'NO'
        config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
        config.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'c++20'

        # Nettoyage des flags -G
        ['OTHER_CFLAGS', 'OTHER_CPLUSPLUSFLAGS', 'OTHER_LDFLAGS', 'OTHER_SWIFT_FLAGS'].each do |key|
          value = config.build_settings[key]
          if value
            if value.is_a?(Array)
              value.reject! { |f| f == '-G' || f == '--serialize-diagnostics' }
            else
              value = value.gsub(/(^|\s)-G(\s|$)/, ' ')
              value = value.gsub(/--serialize-diagnostics/, ' ')
              config.build_settings[key] = value.strip
            end
          end
        end

        # Correction Firestore / Abseil / gRPC
        if target.name.include?('FirebaseFirestore') || target.name.include?('abseil') || target.name.include?('gRPC') || target.name.include?('FirebaseAuth')
          config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= ['$(inherited)']
          config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] << 'GRPC_BAZEL_BUILD=1'
          config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] << 'OPENSSL_NO_ASM=1'
          # On laisse CLANG_ENABLE_MODULES par défaut (YES) car Kotlin en a besoin
        end
      end
    end
  end
end
