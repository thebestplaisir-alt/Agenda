platform :ios, '16.0'

target 'iosApp' do
  use_frameworks! :linkage => :static

  # Le module shared tirera Firebase 11.8.0
  pod 'shared', :path => '../shared'

  post_install do |installer|
    # Calcul du chemin absolu vers la racine du projet
    project_root = File.expand_path('..', __dir__)
    gradlew_path = File.join(project_root, 'gradlew')
    java_home = `/usr/libexec/java_home -v 17`.strip

    installer.pods_project.targets.each do |target|
      target.build_phases.each do |phase|
        if phase.respond_to?(:shell_script) && phase.shell_script.include?('gradlew')
          # On remplace ./gradlew par le chemin ABSOLU et on injecte Java
          # On retire le "set -e" s'il existe pour capturer l'erreur proprement
          original_script = phase.shell_script.gsub('set -e', '')
          phase.shell_script = <<~SH
            export JAVA_HOME="#{java_home}"
            export PATH="$JAVA_HOME/bin:$PATH"
            echo "Building with gradlew at: #{gradlew_path}"
            #{original_script.gsub('./gradlew', gradlew_path)}
          SH
        end
      end

      target.build_configurations.each do |config|
        config.build_settings['ENABLE_USER_SCRIPT_SANDBOXING'] = 'NO'
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '16.0'
        config.build_settings['DEBUG_INFORMATION_FORMAT'] = 'dwarf'

        # Nettoyage des flags -G
        ['OTHER_CFLAGS', 'OTHER_CPLUSPLUSFLAGS', 'OTHER_LDFLAGS', 'OTHER_SWIFT_FLAGS'].each do |key|
          value = config.build_settings[key]
          if value
            if value.is_a?(Array)
              value.reject! { |f| f == '-G' || f == '--serialize-diagnostics' }
            else
              value = value.gsub(/(^|\s)-G(\s|$)/, ' ')
              value = value.gsub(/--serialize-diagnostics/, ' ')
              config.build_settings[key] = value.strip
            end
          end
        end
      end
    end
  end
end
