platform :ios, '16.0'

target 'iosApp' do
  use_frameworks! :linkage => :static

  # Le module shared tirera Firebase 11.4.0
  pod 'shared', :path => '../shared'

  post_install do |installer|
    # On récupère le chemin Java de manière plus robuste
    java_path = `/usr/libexec/java_home -v 17 2>/dev/null || echo $JAVA_HOME`.strip
    if java_path.empty?
      java_path = "/Library/Java/JavaVirtualMachines/temurin-17.jdk/Contents/Home"
    end

    installer.pods_project.targets.each do |target|
      # On injecte Java et on corrige le chemin vers gradlew
      target.build_phases.each do |phase|
        if phase.respond_to?(:shell_script) && phase.shell_script.include?('gradlew')
          # On s'assure que le script peut trouver gradlew même s'il est lancé depuis iosApp/
          # et on injecte JAVA_HOME
          custom_script = <<~SH
            export JAVA_HOME="#{java_path}"
            export PATH="$JAVA_HOME/bin:$PATH"
            if [ -f "./gradlew" ]; then
                GRADLE_PATH="./gradlew"
            elif [ -f "../gradlew" ]; then
                GRADLE_PATH="../gradlew"
            else
                GRADLE_PATH="gradlew"
            fi
            # Remplacement de ./gradlew par le bon chemin dans le script original
            #{phase.shell_script.gsub('./gradlew', '$GRADLE_PATH')}
          SH
          phase.shell_script = custom_script
        end
      end

      target.build_configurations.each do |config|
        config.build_settings['ENABLE_USER_SCRIPT_SANDBOXING'] = 'NO'
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '16.0'
        config.build_settings['ENABLE_BITCODE'] = 'NO'
        config.build_settings['GENERATE_MASTER_OBJECT_FILE'] = 'NO'
        config.build_settings['CLANG_ENABLE_CODE_COVERAGE'] = 'NO'
        config.build_settings['LLVM_LTO'] = 'NO'
        config.build_settings['DEBUG_INFORMATION_FORMAT'] = 'dwarf' # Pas de dSYM pour la rapidité CI
        config.build_settings['CLANG_SERIALIZE_DIAGNOSTICS'] = 'NO'

        # Correction pour les Pods sans Bundle ID
        if config.build_settings['PRODUCT_BUNDLE_IDENTIFIER'].nil?
           config.build_settings['PRODUCT_BUNDLE_IDENTIFIER'] = "com.inchios.agenda.pod.#{target.name.gsub(' ', '-')}"
        end

        # NETTOYAGE PRÉCIS DU FLAG -G (Évite de casser BoringSSL-GRPC)
        ['OTHER_CFLAGS', 'OTHER_CPLUSPLUSFLAGS', 'OTHER_LDFLAGS', 'OTHER_SWIFT_FLAGS'].each do |key|
          value = config.build_settings[key]
          if value
            if value.is_a?(Array)
              # On ne supprime que si le flag est EXACTEMENT '-G'
              value.reject! { |f| f == '-G' || f == '--serialize-diagnostics' }
            else
              # On utilise des expressions régulières pour ne pas toucher à BoringSSL-GRPC
              # On cherche -G entouré d'espaces ou en début/fin de chaîne
              value = value.gsub(/(^|\s)-G(\s|$)/, ' ')
              value = value.gsub(/--serialize-diagnostics/, ' ')
              config.build_settings[key] = value.strip
            end
          end
        end

        # Debug flags for critical targets
        if target.name.include?('abseil') || target.name.include?('BoringSSL')
          puts "==> Flags for #{target.name} (#{config.name}): CFLAGS=#{config.build_settings['OTHER_CFLAGS']}, CXXFLAGS=#{config.build_settings['OTHER_CPLUSPLUSFLAGS']}"
        end

        # CORRECTIF BoringSSL-GRPC et gRPC : Désactivation ASM et nettoyage
        if target.name.include?('BoringSSL-GRPC') || target.name.include?('gRPC') || target.name.include?('FirebaseFirestore') || target.name.include?('abseil')
          config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= ['$(inherited)']
          config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] << 'GRPC_BAZEL_BUILD=1'
          config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] << 'OPENSSL_NO_ASM=1'
          config.build_settings['USE_HEADER_MAP'] = 'NO'
          config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
          config.build_settings['GCC_GENERATE_DEBUGGING_SYMBOLS'] = 'NO'
          config.build_settings['STRIP_INSTALLED_PRODUCT'] = 'YES'
          config.build_settings['CLANG_SERIALIZE_DIAGNOSTICS'] = 'NO'

          # Force le standard C++ pour abseil/gRPC sur Xcode 16
          if target.name.include?('abseil') || target.name.include?('gRPC')
            config.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'c++17'
          end
        end
      end
    end
  end
end
