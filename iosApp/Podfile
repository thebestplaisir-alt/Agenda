platform :ios, '16.0'

target 'iosApp' do
  use_frameworks! :linkage => :static

  # Le module shared tirera Firebase 11.8.0
  pod 'shared', :path => '../shared'

  post_install do |installer|
    installer.pods_project.targets.each do |target|
      # On rend les scripts de build Kotlin bavards pour voir l'erreur réelle
      target.build_phases.each do |phase|
        if phase.respond_to?(:shell_script) && phase.shell_script.include?('gradlew')
          # On injecte le debug et Java directement au début du script généré
          phase.shell_script = "set -x\nexport JAVA_HOME=$(/usr/libexec/java_home -v 17)\nexport PATH=\"$JAVA_HOME/bin:$PATH\"\n" + phase.shell_script
        end
      end

      target.build_configurations.each do |config|
        config.build_settings['ENABLE_USER_SCRIPT_SANDBOXING'] = 'NO'
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '16.0'
        config.build_settings['ENABLE_BITCODE'] = 'NO'
        config.build_settings['GENERATE_MASTER_OBJECT_FILE'] = 'NO'
        config.build_settings['DEBUG_INFORMATION_FORMAT'] = 'dwarf'
        config.build_settings['CLANG_SERIALIZE_DIAGNOSTICS'] = 'NO'

        if config.build_settings['PRODUCT_BUNDLE_IDENTIFIER'].nil?
           config.build_settings['PRODUCT_BUNDLE_IDENTIFIER'] = "com.inchios.agenda.pod.#{target.name.gsub(' ', '-')}"
        end

        # NETTOYAGE PRÉCIS DU FLAG -G
        ['OTHER_CFLAGS', 'OTHER_CPLUSPLUSFLAGS', 'OTHER_LDFLAGS', 'OTHER_SWIFT_FLAGS'].each do |key|
          value = config.build_settings[key]
          if value
            if value.is_a?(Array)
              value.reject! { |f| f == '-G' || f == '--serialize-diagnostics' }
            else
              value = value.gsub(/(^|\s)-G(\s|$)/, ' ')
              value = value.gsub(/--serialize-diagnostics/, ' ')
              config.build_settings[key] = value.strip
            end
          end
        end

        # CORRECTIF BoringSSL-GRPC et gRPC
        if target.name.include?('BoringSSL-GRPC') || target.name.include?('gRPC') || target.name.include?('FirebaseFirestore') || target.name.include?('abseil')
          config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= ['$(inherited)']
          config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] << 'GRPC_BAZEL_BUILD=1'
          config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] << 'OPENSSL_NO_ASM=1'
          config.build_settings['USE_HEADER_MAP'] = 'NO'
          config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'

          if target.name.include?('abseil') || target.name.include?('gRPC')
            config.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'c++17'
          end
        end
      end
    end
  end
end
