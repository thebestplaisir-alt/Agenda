platform :ios, '16.0'

target 'iosApp' do
  use_frameworks! :linkage => :static

  # Le module shared tirera Firebase 11.4.0
  pod 'shared', :path => '../shared'

  post_install do |installer|
    # On récupère le chemin Java de manière plus robuste
    java_path = `/usr/libexec/java_home -v 17 2>/dev/null || echo $JAVA_HOME_17_X64`.strip
    if java_path.empty?
      java_path = `/usr/libexec/java_home -v 17`.strip rescue "/Library/Java/JavaVirtualMachines/temurin-17.jdk/Contents/Home"
    end

    installer.pods_project.targets.each do |target|
      # On injecte Java dans tous les scripts qui appellent gradlew
      target.build_phases.each do |phase|
        if phase.respond_to?(:shell_script) && phase.shell_script.include?('gradlew')
          phase.shell_script = "export JAVA_HOME=\"#{java_path}\"\nexport PATH=\"$JAVA_HOME/bin:$PATH\"\n" + phase.shell_script
        end
      end

      target.build_configurations.each do |config|
        config.build_settings['ENABLE_USER_SCRIPT_SANDBOXING'] = 'NO'
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '16.0'

        # Correction Xcode 16 pour les Pods sans Bundle ID
        if config.build_settings['PRODUCT_BUNDLE_IDENTIFIER'].nil?
           config.build_settings['PRODUCT_BUNDLE_IDENTIFIER'] = "com.inchios.agenda.pod.#{target.name.gsub(' ', '-')}"
        end

        # CORRECTIF BoringSSL-GRPC et gRPC : Suppression du flag -G et optimisation
        if target.name.include?('BoringSSL-GRPC') || target.name.include?('gRPC') || target.name.include?('FirebaseFirestore')
          config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= ['$(inherited)', 'GRPC_BAZEL_BUILD=1']
          config.build_settings['USE_HEADER_MAP'] = 'NO'
          config.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'c++14'

          # Force la suppression du flag -G s'il est présent dans OTHER_CFLAGS ou OTHER_CPLUSPLUSFLAGS
          ['OTHER_CFLAGS', 'OTHER_CPLUSPLUSFLAGS'].each do |key|
            if config.build_settings[key]
              config.build_settings[key] = config.build_settings[key].split(' ').reject { |flag| flag == '-G' }.join(' ')
            end
          end
        end
      end
    end
  end
end
