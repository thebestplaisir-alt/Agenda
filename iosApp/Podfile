platform :ios, '16.0'

target 'iosApp' do
  use_frameworks! :linkage => :static

  # Aligné sur les versions stables
  pod 'FirebaseCore', '10.25.0'
  pod 'FirebaseAuth', '10.25.0'
  pod 'FirebaseFirestore', '10.25.0'

  pod 'shared', :path => '../shared'

  post_install do |installer|
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '16.0'
        config.build_settings['ENABLE_USER_SCRIPT_SANDBOXING'] = 'NO'

        # CORRECTIF BoringSSL-GRPC pour Xcode 15/16
        if target.name == 'BoringSSL-GRPC'
          config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= ['$(inherited)', 'GRPC_BAZEL_BUILD=1']
        end
      end
    end
  end
end
